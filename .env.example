# =============================================================================
# LiTTree Lab Studios — Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in real values. NEVER commit secrets.
# Variables are grouped by subsystem. Public variables are prefixed with NEXT_PUBLIC_.
# =============================================================================

# -----------------------------------------------------------------------------
# Core Application
# -----------------------------------------------------------------------------
# Auth secret for custom JWT signing (generate: openssl rand -hex 32)
AUTH_SECRET=

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: allow anonymous local development shortcuts
ALLOW_ANONYMOUS_DEV=false

# -----------------------------------------------------------------------------
# Clerk Authentication
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Comma-separated Clerk user IDs with admin privileges
ADMIN_CLERK_IDS=
ADMIN_CLERK_ID=

# Admin account seed credentials (only used for admin setup scripts)
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
ADMIN_NAME=
ADMIN_USER_ID=
ADMIN_USER_IDS=

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
# Use test keys for local development (pk_test_..., sk_test_...)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# -----------------------------------------------------------------------------
# AI Providers
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
HUGGING_FACE_API_KEY=
TOGETHER_API_KEY=
FAL_KEY=
MINIMAX_API_KEY=
RECRAFT_API_KEY=

# Default OpenRouter model slug
OPENROUTER_MODEL=google/gemini-2.5-flash

# -----------------------------------------------------------------------------
# Media / External Services
# -----------------------------------------------------------------------------
NEXT_PUBLIC_MEDIA_BASE=
NEXT_PUBLIC_MODEL_NAME=

# Spotify integration
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Push notifications (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@litlabs.net

# Email
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# GitHub App
# -----------------------------------------------------------------------------
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_SETUP_URL=
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=
GITLAB_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Cloudflare R2 (object storage)
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# -----------------------------------------------------------------------------
# AWS S3 (alternative object storage)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# -----------------------------------------------------------------------------
# Supermemory
# -----------------------------------------------------------------------------
SUPERMEMORY_API_KEY=

# -----------------------------------------------------------------------------
# Home Assistant Integration
# -----------------------------------------------------------------------------
HA_API_URL=
HA_WS_URL=
HA_SUPERVISOR_TOKEN=
SUPERVISOR_TOKEN=
HA_ADDON_MODE=false

# -----------------------------------------------------------------------------
# Terminal Server
# -----------------------------------------------------------------------------
# Shared secret between Next.js and terminal-server (>= 32 bytes)
TERMINAL_AUTH_SECRET=
TERMINAL_ALLOWED_ORIGIN=http://localhost:3000
NEXT_PUBLIC_TERMINAL_HTTP_URL=http://localhost:4001
NEXT_PUBLIC_TERMINAL_WS_URL=http://localhost:4001
TERMINAL_SERVER_PORT=4001
TERMINAL_WORKSPACE_ROOT=/tmp/littree-workspaces
TERMINAL_USE_DOCKER=false

# Local Ollama instance for terminal AI
OLLAMA_BASE_URL=http://localhost:11434

# -----------------------------------------------------------------------------
# Local Build/Check API
# -----------------------------------------------------------------------------
# Enable only for local admin tooling; leave false on Vercel.
ENABLE_LOCAL_BUILD_API=false

# Internal server-to-server API key for wallet/credit mutations
INTERNAL_API_KEY=

# -----------------------------------------------------------------------------
# Agent / Voice Monkey / Activepieces
# -----------------------------------------------------------------------------
ENABLE_AGENT_COMMANDS=false
TARGET_AGENT_SLUG=
VOICE_MONKEY_TOKEN=
VOICE_MONKEY_DEVICE=
NEXT_PUBLIC_ACTIVEPIECES_WEBHOOK_URL=
MAX_CONCURRENCY=3
POLL_INTERVAL_MS=30000

# -----------------------------------------------------------------------------
# Discord Webhooks (optional alerting)
# -----------------------------------------------------------------------------
DISCORD_WEBHOOK_URL=
DISCORD_ALERTS_WEBHOOK=
DISCORD_SYSTEM_WEBHOOK=
NEXT_PUBLIC_DISCORD_ADMIN_WEBHOOK=
NEXT_PUBLIC_DISCORD_AGENTS_WEBHOOK=
NEXT_PUBLIC_DISCORD_ERRORS_WEBHOOK=
NEXT_PUBLIC_DISCORD_GENERAL_WEBHOOK=
NEXT_PUBLIC_DISCORD_SALES_WEBHOOK=
NEXT_PUBLIC_DISCORD_SECURITY_WEBHOOK=
NEXT_PUBLIC_DISCORD_SYSTEM_WEBHOOK=

# -----------------------------------------------------------------------------
# Vercel (deploy agent / CI scripts)
# -----------------------------------------------------------------------------
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_PROJECT_NAME=

# -----------------------------------------------------------------------------
# Public site / API helpers
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE=http://localhost:3000
