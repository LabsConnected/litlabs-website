# ============================================
# LiTree Lab Studio — Environment Variables
# ============================================

# JWT signing secret (generate: openssl rand -hex 32)
AUTH_SECRET=

# Admin account credentials
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
ADMIN_NAME=

# Clerk User IDs with admin privileges (comma-separated)
ADMIN_CLERK_IDS=

# API Backend URL
NEXT_PUBLIC_API_BASE=https://api.litlabs.net

# ============================================
# Stripe Payment Configuration
# ============================================

# Stripe secret key (from https://dashboard.stripe.com/apikeys)
# This is the sk_live_... key — keep it secret, never commit to git
STRIPE_SECRET_KEY=

# Stripe publishable key (pk_live_...) — safe for frontend
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe webhook secret (whsec_...) — from your webhook endpoint settings
STRIPE_WEBHOOK_SECRET=

# Stripe price IDs
STRIPE_PRO_PRICE_ID=

# ============================================
# AI Model Configuration
# ============================================

OPENROUTER_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# ============================================
# Terminal Server Authentication
# ============================================

# Shared by the Next.js app and terminal-server. Generate at least 32 random bytes.
TERMINAL_AUTH_SECRET=
NEXT_PUBLIC_TERMINAL_HTTP_URL=http://localhost:4001
NEXT_PUBLIC_TERMINAL_WS_URL=http://localhost:4001
TERMINAL_ALLOWED_ORIGIN=http://localhost:3000
TERMINAL_USE_DOCKER=false

# Enables the admin-only local build/check API. Leave false on hosted deployments.
ENABLE_LOCAL_BUILD_API=false
