# ============================================
# LiTree Lab Studio — Environment Variables
# ============================================

# JWT signing secret (generate: openssl rand -hex 32)
AUTH_SECRET=

# Admin account credentials
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
ADMIN_NAME=

# API Backend URL
NEXT_PUBLIC_API_BASE=https://api.litlabs.net

# ============================================
# Stripe Payment Configuration
# ============================================
# Get these from https://dashboard.stripe.com

# Stripe secret key (sk_live_... or sk_test_...)
STRIPE_SECRET_KEY=

# Stripe webhook secret (whsec_...) - set this after creating the webhook endpoint
STRIPE_WEBHOOK_SECRET=

# Stripe price IDs (create products in Stripe dashboard)
STRIPE_PRO_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...
