{
  "name": "litlabs",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next dev --webpack",
    "dev:turbo": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm typecheck && pnpm build",
    "pages:build": "npx @cloudflare/next-on-pages@1",
    "pages:deploy": "npm run pages:build && npx wrangler pages deploy .vercel/output/static",
    "pages:dev": "npx wrangler pages dev .vercel/output/static --compatibility-flags=nodejs_compat",
    "terminal:dev": "tsx terminal-server/server.ts",
    "terminal:build": "tsc -p terminal-server/tsconfig.json",
    "terminal:start": "node terminal-server/dist/server.js",
    "terminal:build-image": "docker build -t littree-terminal:latest -f docker/Dockerfile.terminal .",
    "dev:all": "concurrently \"pnpm dev\" \"pnpm terminal:dev\""
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.7",
    "@ai-sdk/react": "^4.0.15",
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@clerk/nextjs": "^6.39.5",
    "@google/genai": "^2.8.0",
    "@google/generative-ai": "^0.24.1",
    "@monaco-editor/react": "^4.7.0",
    "@next/third-parties": "^16.2.9",
    "@stripe/stripe-js": "^5.10.0",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.106.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "^7.0.14",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.3",
    "lucide-react": "^1.17.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "sharp": "^0.33.0",
    "socket.io-client": "^4.8.3",
    "stripe": "^18.0.0",
    "supermemory": "^4.24.12",
    "svix": "^1.95.1"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5",
    "@tailwindcss/postcss": "^4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "express": "^5.2.1",
    "node-pty": "^1.1.0",
    "socket.io": "^4.8.3",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "uuid": "^14.0.1"
  }
}
