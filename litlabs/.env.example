# ============================================================
# LiTTree OS / LiTTree Lab Studio Ś Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit secrets to git.
# ============================================================

# App / JWT
AUTH_SECRET=                        # openssl rand -hex 32
NEXT_PUBLIC_SITE_URL=https://litlabs.net

# ============================================================
# Clerk Authentication (required)
# https://dashboard.clerk.com/
# ============================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=  # pk_live_... (or pk_test_... for dev)
CLERK_SECRET_KEY=                   # sk_live_... (or sk_test_... for dev)
CLERK_WEBHOOK_SECRET=               # whsec_... (optional, for Clerk webhooks)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/studio?tool=chat
NEXT_PUBLIC_CLERK_REDIRECT_URI=
NEXT_PUBLIC_CLERK_DOMAIN=

# Comma-separated Clerk user IDs that get admin privileges
ADMIN_CLERK_IDS=

# ============================================================
# Supabase (required)
# https://supabase.com/dashboard
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=           # https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=      # eyJ...
SUPABASE_SERVICE_ROLE_KEY=          # eyJ... (server only)

# ============================================================
# Stripe Payments (required for billing)
# https://dashboard.stripe.com/apikeys
# ============================================================
STRIPE_SECRET_KEY=                   # sk_live_... (or sk_test_...)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY= # pk_live_... (or pk_test_...)
STRIPE_WEBHOOK_SECRET=              # whsec_...
STRIPE_PRO_PRICE_ID=
STRIPE_CREATOR_PRICE_ID=
STRIPE_ELITE_PRICE_ID=

# ============================================================
# AI / LLM Providers (at least one required)
# ============================================================
OPENAI_API_KEY=                     # sk-...
OPENROUTER_API_KEY=                 # sk-or-...
OPENROUTER_MODEL=openrouter/auto
GROQ_API_KEY=                       # gsk_...
GROQ_MODEL=
GEMINI_API_KEY=                     # AI...
GOOGLE_API_KEY=                     # AI... (alias for Gemini, if used)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TOGETHER_API_KEY=                   # ...
RECRAFT_API_KEY=
FAL_KEY=                            # ...
HUGGING_FACE_API_KEY=               # hf_...
MINIMAX_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder
LITT_DEFAULT_PROVIDER=openrouter

# ============================================================
# Media Storage Ś pick one primary backend
# ============================================================
# Cloudflare R2 (recommended for large media)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=                      # e.g. https://media.litlabs.net
NEXT_PUBLIC_MEDIA_BASE=             # public CDN base URL

# Or use Supabase Storage buckets (created via SQL or dashboard):
#   - media
#   - studio-images

# ============================================================
# Terminal / WebSocket Server (required for in-browser terminal)
# ============================================================
TERMINAL_SERVER_PORT=4001
TERMINAL_ALLOWED_ORIGIN=https://litlabs.net
TERMINAL_ALLOWED_ORIGINS=https://litlabs.net,http://localhost:3000
TERMINAL_WORKSPACE_ROOT=/tmp/littree-workspaces
TERMINAL_USE_DOCKER=false
NEXT_PUBLIC_TERMINAL_WS_URL=wss://terminal.litlabs.net

# ============================================================
# Integrations
# ============================================================
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=https://litlabs.net/api/auth/spotify/callback

IFTTT_WEBHOOK_SECRET=

# Web Push Notifications (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@litlabs.net

# Voice Monkey (IoT / voice assistant triggers)
VOICE_MONKEY_API_KEY=
VOICE_MONKEY_API_SECRET=

# Discord (optional Ś for alerts / webhooks)
DISCORD_WEBHOOK_URL=

# Supermemory (optional)
SUPERMEMORY_API_KEY=

# ============================================================
# Admin / internal
# ============================================================
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=                  # bcrypt hash

# ============================================================
# Vercel / CI (usually provided by the platform)
# ============================================================
VERCEL_URL=
VERCEL_ENV=production
