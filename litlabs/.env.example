# ============================================
# LiTree Lab Studio — Environment Variables
# ============================================

# JWT signing secret (generate: openssl rand -hex 32)
AUTH_SECRET=

# Admin account credentials
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
ADMIN_NAME=

# Clerk User IDs with admin privileges (comma-separated)
ADMIN_CLERK_IDS=

# API Backend URL
NEXT_PUBLIC_API_BASE=https://api.litlabs.net

# ============================================
# Stripe Payment Configuration
# ============================================

# Stripe secret key (from https://dashboard.stripe.com/apikeys)
# This is the sk_live_... key — keep it secret, never commit to git
STRIPE_SECRET_KEY=

# Stripe publishable key (pk_live_...) — safe for frontend
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe webhook secret (whsec_...) — from your webhook endpoint settings
STRIPE_WEBHOOK_SECRET=

# Stripe price IDs
STRIPE_PRO_PRICE_ID=

# ============================================
# AI Model Configuration
# ============================================

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto

GROQ_API_KEY=
GROQ_MODEL=

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder

LITT_DEFAULT_PROVIDER=openrouter

GEMINI_API_KEY=
GOOGLE_API_KEY=
