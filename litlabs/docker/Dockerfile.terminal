FROM node:22-bookworm

RUN apt-get update && apt-get install -y \
    git \
    curl \
    wget \
    nano \
    vim \
    python3 \
    python3-pip \
    build-essential \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g pnpm bun npm-check-updates typescript tsx

WORKDIR /workspace

CMD ["/bin/bash"]
