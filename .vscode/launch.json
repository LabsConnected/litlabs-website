{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: debug browser",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true
    },
    {
      "name": "Next.js: debug server (Turbopack)",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm dev",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Next.js: debug server (Webpack fallback)",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm dev:webpack",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Node: attach to port 9229",
      "type": "pwa-node",
      "request": "attach",
      "port": 9229,
      "restart": true,
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true
    }
  ],
  "compounds": [
    {
      "name": "Next.js: debug full stack",
      "configurations": [
        "Next.js: debug server (Turbopack)",
        "Next.js: debug browser"
      ],
      "stopAll": true
    }
  ]
}
