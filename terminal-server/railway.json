{
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "terminal-server/Dockerfile"
  },
  "deploy": {
    "startCommand": "node terminal-server/dist/server.js",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
