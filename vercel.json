{
  "buildCommand": "pnpm build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "installCommand": "pnpm install",
  "crons": [
    {
      "path": "/api/deployments/digest",
      "schedule": "0 9 * * 1-5"
    }
  ],
  "functions": {
    "src/app/api/media/generate/route.ts": { "maxDuration": 60 },
    "src/app/api/media/generate-video/route.ts": { "maxDuration": 60 },
    "src/app/api/media/generate-audio/route.ts": { "maxDuration": 60 },
    "src/app/api/media/generate-music/route.ts": { "maxDuration": 60 },
    "src/app/api/media/analyze-video/route.ts": { "maxDuration": 60 },
    "src/app/api/media/transcribe/route.ts": { "maxDuration": 60 },
    "src/app/api/media/video-status/route.ts": { "maxDuration": 30 },
    "src/app/api/media/video-download/route.ts": { "maxDuration": 60 },
    "src/app/api/music/generate/route.ts": { "maxDuration": 60 },
    "src/app/api/studio/video/route.ts": { "maxDuration": 120 },
    "src/app/api/agents/run/route.ts": { "maxDuration": 60 },
    "src/app/api/orchestrate/route.ts": { "maxDuration": 60 },
    "src/app/api/ai/chat/route.ts": { "maxDuration": 60 },
    "src/app/api/ai-chat/route.ts": { "maxDuration": 60 },
    "src/app/api/chat/unified/route.ts": { "maxDuration": 60 },
    "src/app/api/gemini/chat/route.ts": { "maxDuration": 60 },
    "src/app/api/tts/route.ts": { "maxDuration": 60 },
    "src/app/api/bridge/cli/route.ts": { "maxDuration": 60 }
  }
}
