{
  "name": "@litt/code-cli",
  "version": "0.1.0",
  "description": "LiTT Code agentic development CLI",
  "type": "module",
  "bin": {
    "litt": "./dist/litt-code-cli.js",
    "litt-code": "./dist/litt-code-cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "pnpm --filter @litt/agent-core build && rimraf dist && tsc -p tsconfig.json",
    "dev": "pnpm --filter @litt/agent-core build && tsx src/litt-code-cli.tsx",
    "start": "node dist/litt-code-cli.js",
    "validate": "pnpm typecheck && pnpm build && node dist/litt-code-cli.js --help"
  },
  "dependencies": {
    "@litt/agent-core": "workspace:*",
    "commander": "^15.0.0",
    "ink": "^7.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19.2.17",
    "rimraf": "^6.1.3",
    "tsx": "^4.23.1",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=22"
  }
}
